{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "rootDir": "./src",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "emitDeclarationOnly": true,
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
